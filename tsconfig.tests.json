{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "vite/client"],
    "rootDir": ".",
    "outDir": ".temp/tests",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"]
    },
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "app/.server/constants/product.ts",
    "app/.server/libs/base-auth.ts",
    "app/.server/services/order-errors.ts",
    "tests/unit/**/*.ts"
  ]
}

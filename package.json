{
  "name": "linkedin—translator",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types --include-runtime false",
    "creem:heartbeat": "node scripts/creem-heartbeat.mjs",
    "deploy": "pnpm run build && wrangler deploy",
    "deploy:versions": "wrangler versions upload --preview-alias production",
    "dev": "react-router dev",
    "dev:cf": "set CLOUDFLARE_DEV=1&& react-router dev",
    "postinstall": "npm run cf-typegen",
    "preview": "pnpm run build && wrangler dev --local",
    "test:unit": "tsc -p tsconfig.tests.json && node .temp/tests/tests/unit/index.test.js",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
    "db:generate": "drizzle-kit generate --config app/.server/drizzle/config.ts",
    "db:migrate": "drizzle-kit migrate --config app/.server/drizzle/config.ts",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:check:local": "node scripts/d1-check.mjs --local",
    "db:check:remote": "node scripts/d1-check.mjs --remote",
    "db:check": "pnpm run db:check:local && pnpm run db:check:remote",
    "db:gate:remote": "node scripts/d1-gate-remote.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@ai-sdk/openai": "^1.3.22",
    "@fontsource/libre-baskerville": "^5.2.6",
    "@markdoc/markdoc": "^0.5.2",
    "@react-oauth/google": "^0.12.2",
    "@react-router/cloudflare": "^7.5.3",
    "@react-router/fs-routes": "^7.5.3",
    "ai": "^4.3.16",
    "clsx": "^2.1.1",
    "currency.js": "^2.0.4",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.41.0",
    "google-auth-library": "^9.15.1",
    "isbot": "^5.1.27",
    "jszip": "^3.10.1",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.513.0",
    "motion": "^12.34.3",
    "nanoid": "^5.1.5",
    "react": "^19.1.0",
    "react-compare-slider": "^3.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.6.2",
    "zod": "^3.25.56",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.12",
    "@react-router/dev": "^7.6.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "daisyui": "^5.0.43",
    "drizzle-kit": "^0.31.1",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.19.1"
  }
}
